# ── Серверные переменные (Vercel → Settings → Environment Variables) ──────────
# Base64-закодированные credentials GigaChat API (Client ID + Client Secret).
# Получить: https://developers.sber.ru/studio/
GIGACHAT_CREDENTIALS=your_base64_credentials_here

# Scope доступа к GigaChat API (для физических лиц — GIGACHAT_API_PERS)
GIGACHAT_SCOPE=GIGACHAT_API_PERS

# ── Клиентские переменные (публичны, попадают в бандл) ───────────────────────
# Установите "true" чтобы скрыть форму авторизации (используются серверные credentials)
VITE_SKIP_AUTH=false